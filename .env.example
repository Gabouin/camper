# Slack Bot
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# Channels (use IDs, not names)
SLACK_HELP_CHANNEL=C...
SLACK_TICKET_CHANNEL=C...

# Admins (comma-separated user IDs)
SLACK_ADMIN_USER_IDS=U...,U...

# FAQ link (optional)
FAQ_URL=https://...

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/camper

# Dashboard
DASHBOARD_PORT=3001
SESSION_SECRET=change-me-in-production

# Slack OAuth (for dashboard login)
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
SLACK_DASHBOARD_REDIRECT_URI=http://localhost:3001/auth/callback
